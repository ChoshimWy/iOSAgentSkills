{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ios-agent-skills.local/schemas/agent-packet-v1.schema.json",
  "title": "iOS Design Agent Packet v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_version",
    "task",
    "reference",
    "environment",
    "nodes",
    "tokens",
    "bindings",
    "states",
    "interactions",
    "responsive",
    "accessibility",
    "code_anchors",
    "unknowns",
    "acceptance",
    "context_budget"
  ],
  "properties": {
    "packet_version": { "const": "1.0.0" },
    "task": {
      "type": "object",
      "required": ["screen", "target_kind", "target_id", "requested_states"],
      "properties": {
        "screen": { "type": "string", "minLength": 1 },
        "target_kind": { "enum": ["screen", "region", "component", "state"] },
        "target_id": { "type": "string", "minLength": 1 },
        "requested_states": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "reference": {
      "type": "object",
      "required": ["image", "source_hash", "viewport", "scale", "appearance", "locale"],
      "properties": {
        "image": { "type": "string", "minLength": 1 },
        "crop": { "type": "object" },
        "source_hash": { "type": "string", "minLength": 8 },
        "viewport": {
          "type": "object",
          "required": ["width", "height"],
          "properties": {
            "width": { "type": "number", "exclusiveMinimum": 0 },
            "height": { "type": "number", "exclusiveMinimum": 0 }
          }
        },
        "scale": { "type": "number", "exclusiveMinimum": 0 },
        "appearance": { "enum": ["light", "dark"] },
        "locale": { "type": "string", "minLength": 2 }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "ui_framework", "minimum_os", "device"],
      "properties": {
        "platform": { "enum": ["iOS", "iPadOS"] },
        "ui_framework": { "enum": ["UIKit", "SwiftUI", "mixed-ui"] },
        "minimum_os": { "type": "string", "minLength": 1 },
        "device": { "type": "string", "minLength": 1 }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "enum": ["screen", "region", "component", "primitive"] },
          "role": { "type": "string", "minLength": 1 },
          "parent": { "type": "string", "minLength": 1 },
          "layout": { "type": "object" },
          "style": { "type": "object" },
          "node_state": { "type": "object" },
          "component": {
            "type": "object",
            "required": ["design_id", "semantic_role", "reuse_policy"],
            "properties": {
              "design_id": { "type": "string", "minLength": 1 },
              "semantic_role": { "type": "string", "minLength": 1 },
              "reuse_policy": { "enum": ["required", "preferred", "native", "custom-allowed", "asset-only"] }
            }
          },
          "token_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "binding_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "state_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "interaction_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "tokens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "value"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "value": {}
        }
      }
    },
    "bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "design_id", "reuse_policy", "framework", "symbol", "source"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "design_id": { "type": "string", "minLength": 1 },
          "reuse_policy": { "enum": ["required", "preferred", "native", "custom-allowed", "asset-only"] },
          "framework": { "enum": ["UIKit", "SwiftUI"] },
          "symbol": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 }
        }
      }
    },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "string", "minLength": 1 } }
      }
    },
    "interactions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "event", "from", "to"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "event": { "type": "string", "minLength": 1 },
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "side_effect": { "type": "string" },
          "presentation": { "type": "string" },
          "animation": { "type": "string" }
        }
      }
    },
    "responsive": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["when", "layout"],
        "properties": {
          "when": { "type": "object" },
          "layout": { "type": "object" }
        }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dynamic_type", "voice_over", "reduce_motion"],
      "properties": {
        "dynamic_type": { "type": "boolean" },
        "voice_over": { "type": "boolean" },
        "reduce_motion": { "type": "boolean" }
      }
    },
    "code_anchors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "symbol", "source"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "symbol": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 }
        }
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "reason", "severity", "source"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["blocking", "non-blocking"] },
          "source": { "type": "string", "minLength": 1 }
        }
      }
    },
    "acceptance": {
      "type": "object",
      "required": ["required_regions"],
      "properties": {
        "required_regions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "max_geometry_deviation_pt": { "type": "number", "minimum": 0 }
      }
    },
    "context_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["estimated_tokens", "max_tokens", "within_budget"],
      "properties": {
        "estimated_tokens": { "type": "integer", "minimum": 0 },
        "max_tokens": { "type": "integer", "minimum": 1 },
        "within_budget": { "type": "boolean" }
      }
    }
  }
}
