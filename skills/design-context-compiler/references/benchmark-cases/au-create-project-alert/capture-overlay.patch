+private final class AUCreateProjectDesignCaptureViewController: UIViewController {
+    private let canvasSize = CGSize(width: 728, height: 471)
+    private let readyLabel = UILabel()
+    private lazy var alertView = AUCreateProjectAlertView(text: "Scene 01") { _, _ in }
+
+    override func viewDidLoad() {
+        super.viewDidLoad()
+        overrideUserInterfaceStyle = .dark
+        view.backgroundColor = .black
+        alertView.frame.origin = .zero
+        view.addSubview(alertView)
+
+        readyLabel.accessibilityIdentifier = "design.capture.pending"
+        readyLabel.isAccessibilityElement = true
+        readyLabel.textColor = .white
+        readyLabel.frame = CGRect(x: 0, y: canvasSize.height + 8, width: 200, height: 30)
+        view.addSubview(readyLabel)
+    }
+
+    override func viewDidAppear(_ animated: Bool) {
+        super.viewDidAppear(animated)
+        DispatchQueue.main.async { [weak self] in
+            self?.writeCapture()
+        }
+    }
+
+    private func writeCapture() {
+        alertView.setNeedsLayout()
+        alertView.layoutIfNeeded()
+        guard
+            let nameInput = descendant(identifier: "project.alert.create.input.container", in: alertView),
+            let cancel = descendant(identifier: "project.alert.create.cancel", in: alertView),
+            let confirm = descendant(identifier: "project.alert.create.confirm", in: alertView)
+        else {
+            setCaptureError()
+            return
+        }
+        let entries = (0..<4).compactMap {
+            descendant(identifier: "project.alert.create.entry.\($0)", in: alertView)
+        }
+        guard entries.count == 4 else {
+            setCaptureError()
+            return
+        }
+        guard let fixtureEntry = entries[0] as? UIControl else {
+            setCaptureError()
+            return
+        }
+        fixtureEntry.sendActions(for: .touchUpInside)
+        alertView.layoutIfNeeded()
+        guard fixtureEntry.isSelected,
+              entries.dropFirst().allSatisfy({ ($0 as? UIControl)?.isSelected == false }) else {
+            setCaptureError()
+            return
+        }
+
+        let format = UIGraphicsImageRendererFormat()
+        format.scale = 1
+        format.opaque = true
+        let image = UIGraphicsImageRenderer(size: canvasSize, format: format).image { context in
+            UIColor.black.setFill()
+            context.fill(CGRect(origin: .zero, size: canvasSize))
+            alertView.layer.render(in: context.cgContext)
+        }
+        guard let png = image.pngData() else {
+            setCaptureError()
+            return
+        }
+
+        let regions: [[String: Any]] = [
+            region(id: "create-project-alert", view: alertView, root: alertView,
+                   runtimeType: String(describing: type(of: alertView)),
+                   accessibilityIdentifier: alertView.accessibilityIdentifier ?? "",
+                   parentID: nil, childIDs: ["name-input", "entry-mode-grid", "footer-actions"]),
+            region(id: "name-input", view: nameInput, root: alertView,
+                   runtimeType: String(describing: type(of: nameInput)),
+                   accessibilityIdentifier: nameInput.accessibilityIdentifier ?? "",
+                   parentID: "create-project-alert", childIDs: []),
+            unionRegion(id: "entry-mode-grid", views: entries, root: alertView,
+                        runtimeType: "\(String(describing: type(of: entries[0])))[]",
+                        accessibilityIdentifier: "project.alert.create.entry.*"),
+            unionRegion(id: "footer-actions", views: [cancel, confirm], root: alertView,
+                        runtimeType: "\(String(describing: type(of: cancel)))[]",
+                        accessibilityIdentifier: "project.alert.create.cancel+project.alert.create.confirm")
+        ]
+        let payload: [String: Any] = [
+            "capture_raw_version": "1.0.0",
+            "environment": [
+                "viewport": ["width": Int(canvasSize.width), "height": Int(canvasSize.height)],
+                "scale": 1,
+                "appearance": "dark",
+                "locale": "en_US"
+            ],
+            "state": ["id": "fixture-selected", "selected_entry_index": 0],
+            "regions": regions,
+            "bindings": [[
+                "id": "binding.create-project-alert.uikit",
+                "region_id": "create-project-alert",
+                "runtime_type": String(describing: type(of: alertView))
+            ]]
+        ]
+        do {
+            let documents = try FileManager.default.url(for: .documentDirectory,
+                                                        in: .userDomainMask,
+                                                        appropriateFor: nil,
+                                                        create: true)
+            try png.write(to: documents.appendingPathComponent("dcc-au-create-project-alert-actual.png"), options: .atomic)
+            let json = try JSONSerialization.data(withJSONObject: payload, options: [.prettyPrinted, .sortedKeys])
+            try json.write(to: documents.appendingPathComponent("dcc-au-create-project-alert-raw.json"), options: .atomic)
+            readyLabel.text = "capture ready"
+            readyLabel.accessibilityIdentifier = "design.capture.ready"
+        } catch {
+            setCaptureError()
+        }
+    }
+
+    private func setCaptureError() {
+        readyLabel.text = "capture error"
+        readyLabel.accessibilityIdentifier = "design.capture.error"
+    }
+
+    private func descendant(identifier: String, in root: UIView) -> UIView? {
+        if root.accessibilityIdentifier == identifier { return root }
+        for child in root.subviews {
+            if let match = descendant(identifier: identifier, in: child) { return match }
+        }
+        return nil
+    }
+
+    private func region(id: String,
+                        view: UIView,
+                        root: UIView,
+                        runtimeType: String,
+                        accessibilityIdentifier: String,
+                        parentID: String?,
+                        childIDs: [String]) -> [String: Any] {
+        let frame = view.convert(view.bounds, to: root)
+        return [
+            "id": id,
+            "frame": framePayload(frame),
+            "runtime_type": runtimeType,
+            "accessibility_identifier": accessibilityIdentifier,
+            "visible": !view.isHidden && view.alpha > 0.01,
+            "parent_id": parentID.map { $0 as Any } ?? NSNull(),
+            "child_ids": childIDs
+        ]
+    }
+
+    private func unionRegion(id: String,
+                             views: [UIView],
+                             root: UIView,
+                             runtimeType: String,
+                             accessibilityIdentifier: String) -> [String: Any] {
+        let frame = views.map { $0.convert($0.bounds, to: root) }.reduce(CGRect.null) { $0.union($1) }
+        return [
+            "id": id,
+            "frame": framePayload(frame),
+            "runtime_type": runtimeType,
+            "accessibility_identifier": accessibilityIdentifier,
+            "visible": views.allSatisfy { !$0.isHidden && $0.alpha > 0.01 },
+            "parent_id": "create-project-alert",
+            "child_ids": []
+        ]
+    }
+
+    private func framePayload(_ frame: CGRect) -> [String: CGFloat] {
+        ["x": frame.minX, "y": frame.minY, "width": frame.width, "height": frame.height]
+    }
+}
