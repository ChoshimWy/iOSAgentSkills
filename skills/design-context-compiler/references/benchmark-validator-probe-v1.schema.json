{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ios-agent-skills.local/schemas/benchmark-validator-probe-v1.schema.json",
  "title": "Design Context Benchmark Validator Probe v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "validator_probe_version",
    "case_id",
    "variant",
    "validator_id",
    "capture_adapter_sha256",
    "environment",
    "actual_screenshot",
    "regions",
    "bindings"
  ],
  "properties": {
    "validator_probe_version": { "const": "1.0.0" },
    "case_id": { "type": "string", "minLength": 1 },
    "variant": { "enum": ["screenshot-only", "ui-ir", "ui-ir-with-binding"] },
    "validator_id": { "type": "string", "minLength": 1 },
    "capture_adapter_sha256": { "$ref": "#/$defs/sha256" },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["viewport", "scale", "appearance", "locale"],
      "properties": {
        "viewport": { "$ref": "#/$defs/size" },
        "scale": { "type": "number", "exclusiveMinimum": 0 },
        "appearance": { "enum": ["light", "dark"] },
        "locale": { "type": "string", "minLength": 2 }
      }
    },
    "actual_screenshot": { "$ref": "#/$defs/fileEvidence" },
    "regions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "frame", "runtime_type", "accessibility_identifier", "visible", "parent_id", "child_ids"],
        "properties": {
          "id": { "$ref": "#/$defs/identifier" },
          "frame": { "$ref": "#/$defs/frame" },
          "runtime_type": { "type": "string", "minLength": 1 },
          "accessibility_identifier": { "type": "string", "minLength": 1 },
          "visible": { "type": "boolean" },
          "parent_id": { "oneOf": [{ "$ref": "#/$defs/identifier" }, { "type": "null" }] },
          "child_ids": {
            "type": "array",
            "uniqueItems": true,
            "items": { "$ref": "#/$defs/identifier" }
          }
        }
      }
    },
    "bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "region_id", "runtime_type"],
        "properties": {
          "id": { "$ref": "#/$defs/identifier" },
          "region_id": { "$ref": "#/$defs/identifier" },
          "runtime_type": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "identifier": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "size": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number", "minimum": 0 },
        "height": { "type": "number", "minimum": 0 }
      }
    },
    "fileEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
