{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ios-agent-skills.local/schemas/benchmark-visual-diff-v1.schema.json",
  "title": "Design Context Benchmark Visual Diff v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["visual_diff_version", "case_id", "variant", "validator_id", "validator_adapter_sha256", "validator_probe_sha256", "capture_adapter_sha256", "reference_sha256", "actual_sha256", "regions"],
  "properties": {
    "visual_diff_version": { "const": "1.1.0" },
    "case_id": { "type": "string", "minLength": 1 },
    "variant": { "enum": ["screenshot-only", "ui-ir", "ui-ir-with-binding"] },
    "validator_id": { "type": "string", "minLength": 1 },
    "validator_adapter_sha256": { "$ref": "#/$defs/sha256" },
    "validator_probe_sha256": { "$ref": "#/$defs/sha256" },
    "capture_adapter_sha256": { "$ref": "#/$defs/sha256" },
    "reference_sha256": { "$ref": "#/$defs/sha256" },
    "actual_sha256": { "$ref": "#/$defs/sha256" },
    "regions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "visual", "layout_deviation_pt", "pixel_difference_ratio", "anchors"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "visual": { "enum": ["passed", "failed"] },
          "layout_deviation_pt": { "type": "number", "minimum": 0 },
          "pixel_difference_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
          "anchors": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "metric", "reference_value", "actual_value", "deviation_pt"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "metric": { "enum": ["position", "size", "spacing"] },
                "reference_value": { "$ref": "#/$defs/vector" },
                "actual_value": { "$ref": "#/$defs/vector" },
                "deviation_pt": { "type": "number", "minimum": 0 }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "vector": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "items": { "type": "number" }
    }
  }
}
