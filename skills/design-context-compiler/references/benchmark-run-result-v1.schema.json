{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ios-agent-skills.local/schemas/benchmark-run-result-v1.schema.json",
  "title": "Design Context Benchmark Run Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_result_version",
    "status",
    "variant",
    "model",
    "reasoning",
    "code_baseline_commit",
    "reference_sha256",
    "provider_run_id",
    "model_usage",
    "metrics",
    "regions",
    "evidence"
  ],
  "properties": {
    "run_result_version": { "const": "1.1.0" },
    "status": { "enum": ["passed", "failed"] },
    "variant": { "enum": ["screenshot-only", "ui-ir", "ui-ir-with-binding"] },
    "model": { "type": "string", "minLength": 1 },
    "reasoning": { "type": "string", "minLength": 1 },
    "code_baseline_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "reference_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "provider_run_id": { "type": "string", "minLength": 1 },
    "model_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens", "output_tokens"],
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout_deviation_pt", "component_reuse_rate", "magic_numbers", "repair_iterations", "manual_minutes"],
      "properties": {
        "layout_deviation_pt": { "type": "number", "minimum": 0 },
        "component_reuse_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "magic_numbers": { "type": "integer", "minimum": 0 },
        "repair_iterations": { "type": "integer", "minimum": 0 },
        "manual_minutes": { "type": "number", "minimum": 0 }
      }
    },
    "regions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "structure", "semantic", "visual", "layout_deviation_pt"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "structure": { "enum": ["passed", "failed"] },
          "semantic": { "enum": ["passed", "failed"] },
          "visual": { "enum": ["passed", "failed"] },
          "layout_deviation_pt": { "type": "number", "minimum": 0 }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actual_screenshot", "validator_probe", "semantic_snapshot", "visual_diff", "run_observation"],
      "properties": {
        "actual_screenshot": { "$ref": "#/$defs/fileEvidence" },
        "validator_probe": { "$ref": "#/$defs/fileEvidence" },
        "semantic_snapshot": { "$ref": "#/$defs/fileEvidence" },
        "visual_diff": { "$ref": "#/$defs/fileEvidence" },
        "run_observation": { "$ref": "#/$defs/fileEvidence" }
      }
    }
  },
  "$defs": {
    "fileEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
