{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ios-agent-skills.local/schemas/benchmark-semantic-evidence-v1.schema.json",
  "title": "Design Context Benchmark Semantic Evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["semantic_evidence_version", "case_id", "variant", "validator_id", "validator_adapter_sha256", "validator_probe_sha256", "capture_adapter_sha256", "regions", "required_bindings", "unmapped_literals"],
  "properties": {
    "semantic_evidence_version": { "const": "1.1.0" },
    "case_id": { "type": "string", "minLength": 1 },
    "variant": { "enum": ["screenshot-only", "ui-ir", "ui-ir-with-binding"] },
    "validator_id": { "type": "string", "minLength": 1 },
    "validator_adapter_sha256": { "$ref": "#/$defs/sha256" },
    "validator_probe_sha256": { "$ref": "#/$defs/sha256" },
    "capture_adapter_sha256": { "$ref": "#/$defs/sha256" },
    "regions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "frame", "structure", "semantic"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "frame": { "$ref": "#/$defs/frame" },
          "structure": { "enum": ["passed", "failed"] },
          "semantic": { "enum": ["passed", "failed"] }
        }
      }
    },
    "required_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "registry_entry_id", "code_symbol", "source", "region_id", "runtime_type", "runtime_observed", "reused", "locations"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "registry_entry_id": { "type": "string", "minLength": 1 },
          "code_symbol": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "region_id": { "type": "string", "minLength": 1 },
          "runtime_type": { "type": "string", "minLength": 1 },
          "runtime_observed": { "type": "boolean" },
          "reused": { "type": "boolean" },
          "locations": {
            "type": "array",
            "items": { "$ref": "#/$defs/location" }
          }
        }
      }
    },
    "unmapped_literals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "value", "location"],
        "properties": {
          "kind": { "enum": ["layout", "color", "typography", "radius", "shadow"] },
          "value": { "type": ["string", "number"] },
          "location": { "$ref": "#/$defs/location" }
        }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number", "minimum": 0 },
        "height": { "type": "number", "minimum": 0 }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "line"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "line": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
